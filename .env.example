# .env.example

# Discord API
DISCORD_TOKEN=your_discord_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=your_database_name_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=1d
